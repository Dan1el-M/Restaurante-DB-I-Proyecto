# ===== BASE DE DATOS =====
DATABASE_URL=postgresql://user:password@localhost:5432/restaurante

# ===== KEYCLOAK =====
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=restaurant-realm
KEYCLOAK_CLIENT_ID=restaurant-client
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
KEYCLOAK_TOKEN_AUDIENCE=account

# ===== KEYCLOAK ADMIN (para crear/eliminar usuarios) =====
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ===== API =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
